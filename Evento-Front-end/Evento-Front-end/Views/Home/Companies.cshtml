@model Evento_Front_end.ViewModels.Company.ShowAllCompaniesVM
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">List of companies:</h1>
</div>


@if (Model?.Companies != null)
{
<ul>
@foreach (var company in Model.Companies)
    {
        <li>@company.Name</li>
        <li>@company.Description</li>
        <li>@company.Email</li>
        <h1>
            <a asp-action="CompanyDetails" asp-route-companyId="@company.CompanyID">
                    @company.Name
            </a>
        </h1>
        <h1></h1>
            <h1></h1>
    }
    </ul>
}
else
{
    <p>No companies found</p>
}