@model Evento_Front_end.ViewModels.Company.RequestsVM

@{
    ViewData["Title"] = "Jobs";
}

<form asp-controller="Home" asp-action="Requests" method="get">

    <label>Select company</label>

    <select name="companyId">
        @foreach (var company in Model.Companies)
        {
            <option value="@company.CompanyID">
                @company.Name
            </option>
        }
    </select>

    <button type="submit">
        Show Requests
    </button>

</form>

<div class="text-center">
    <h1 class="display-4">Accepted jobs</h1>
</div>

@if (Model.RequestRows.Any())
{
    <ul class="company-list">
        @foreach (var job in Model.RequestRows)
        {
            <li class="company-card">
                <strong>Customer:</strong> @job.CustomerName <br />
                <strong>Service:</strong> @job.ServiceName <br />
                <strong>Description:</strong> @job.Description <br />
                <strong>Accepted at:</strong> @job.RespondedAt?.ToString("dd/MM/yyyy HH:mm") <br />
                <input type="hidden" name="requestId" value="@job.RequestID" />

                <div class="d-flex gap-2 mt-2">

                <form asp-controller="Request" asp-action="CancelJob" method="post">
                <input type="hidden" name="requestId" value="@job.RequestID" />
                <button type="submit">Cancel</button>
                </form>

                <form asp-controller="Request" asp-action="FinishJob" method="post">
                <input type="hidden" name="requestId" value="@job.RequestID" />
                <button type="submit">Done</button>
                </form>
                </div>
            </li>
        }
    </ul>
}
else
{
    <p>No approved jobs</p>
}